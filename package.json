{
  "name": "jxufe-tech",
  "version": "1.0.0",
  "private": true,
  "description": "江西财经大学数智技术协会 — 官网前端 + 无头 CMS 后端",
  "scripts": {
    "dev": "node scripts/kill-port.cjs 3003 5173 && concurrently -n fe,be -c cyan,green --kill-others --handle-input \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && vite",
    "dev:backend": "cd backend && nest start --watch",
    "kill:ports": "node scripts/kill-port.cjs 3003 5173",
    "start:backend": "cd backend && nest start",
    "start:backend:prod": "cd backend && node dist/main",
    "build": "cd frontend && vite build && cd ../backend && nest build",
    "build:frontend": "cd frontend && vite build",
    "build:backend": "cd backend && nest build",
    "preview": "cd frontend && vite preview",
    "lint": "cd backend && eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "cd backend && prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "cd backend && jest",
    "test:watch": "cd backend && jest --watch",
    "test:cov": "cd backend && jest --coverage",
    "test:debug": "cd backend && node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cd backend && jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.1",
    "@scalar/nestjs-api-reference": "^1.2.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.10.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.1.1",
    "multer": "^2.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^1.0.0",
    "vue": "^3.5.24",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "npm:rolldown-vite@7.2.5",
    "vite-plugin-pages": "^0.33.3",
    "vite-ssg": "^28.3.0",
    "vue-tsc": "^3.2.8"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5",
    "shell-quote": "^1.8.4"
  }
}
